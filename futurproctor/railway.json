{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install --upgrade pip && pip install -r requirements.txt && python manage.py collectstatic --no-input"
  },
  "deploy": {
    "startCommand": "python manage.py migrate && gunicorn futurproctor.wsgi --bind 0.0.0.0:$PORT --workers 2 --threads 4 --timeout 120",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
